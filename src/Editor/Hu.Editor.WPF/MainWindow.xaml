<Window x:Class="Hu.Editor.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="安定堂家谱编纂端 V2.0"
        Width="1400" Height="900"
        Background="{StaticResource BackgroundColor}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" MinWidth="200" MaxWidth="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 侧边栏 -->
        <Border Grid.Column="0" Background="White" CornerRadius="0,12,12,0" 
                Margin="0,8,8,8" Padding="16">
            <StackPanel>
                <!-- Logo -->
                <StackPanel Orientation="Horizontal" Margin="0,12,0,20">
                    <TextBlock Text="🏮" FontSize="24" Margin="0,0,8,0"/>
                    <TextBlock Text="安定堂" FontSize="18" FontWeight="Bold" 
                               Foreground="{StaticResource PrimaryColor}"/>
                </StackPanel>

                <!-- 导航菜单 -->
                <TextBlock Text="📖 编纂管理" FontSize="14" Margin="8,8,8,8"
                           Foreground="{StaticResource PrimaryColor}" Cursor="Hand">
                    <TextBlock.Background>
                        <SolidColorBrush Color="#2C5F5C" Opacity="0.1"/>
                    </TextBlock.Background>
                </TextBlock>
                
                <TextBlock Text="🌳 世系树" FontSize="14" Margin="8,4,8,8"
                           Foreground="{StaticResource SecondaryColor}" Cursor="Hand" Padding="8,8"/>
                
                <TextBlock Text="📷 素材管理" FontSize="14" Margin="8,4,8,8"
                           Foreground="{StaticResource SecondaryColor}" Cursor="Hand" Padding="8,8"/>
                
                <TextBlock Text="🔍 检索查询" FontSize="14" Margin="8,4,8,8"
                           Foreground="{StaticResource SecondaryColor}" Cursor="Hand" Padding="8,8"/>
                
                <TextBlock Text="📥 待审数据" FontSize="14" Margin="8,4,8,8"
                           Foreground="{StaticResource WarningColor}" Cursor="Hand" Padding="8,8">
                    <TextBlock.Inlines>
                        <Run Text="📥 待审数据"/>
                        <Run Text=" (3)" FontWeight="Bold" Foreground="Red"/>
                    </TextBlock.Inlines>
                </TextBlock>
                
                <TextBlock Text="⚙️ 系统设置" FontSize="14" Margin="8,4,8,8"
                           Foreground="{StaticResource SecondaryColor}" Cursor="Hand" Padding="8,8"/>
            </StackPanel>
        </Border>

        <!-- 主内容区 -->
        <Border Grid.Column="1" Margin="8" CornerRadius="12" Background="White">
            <Grid>
                <!-- 顶部导航栏 -->
                <Border Height="56" Background="{StaticResource PrimaryColor}" 
                        CornerRadius="12,12,0,0" Padding="16,0">
                    <Grid>
                        <TextBlock Text="编纂管理" FontSize="16" Foreground="White" 
                                   FontWeight="Bold" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <!-- 封谱状态 -->
                            <Border Background="#C9A962" CornerRadius="20" Padding="12,4" Margin="0,0,12,0">
                                <TextBlock Text="🔒 已封谱" Foreground="White" FontSize="12" FontWeight="Bold"/>
                            </Border>
                            <!-- 用户信息 -->
                            <TextBlock Text="👤 总管理员" Foreground="White" FontSize="13" 
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 内容面板 -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16">
                    <StackPanel>
                        <!-- 统计卡片 -->
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="800" FontSize="28" FontWeight="Bold" 
                                               Foreground="{StaticResource PrimaryColor}"/>
                                    <TextBlock Text="在册人数" FontSize="12" 
                                               Foreground="{StaticResource SubTextColor}"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="25" FontSize="28" FontWeight="Bold" 
                                               Foreground="{StaticResource SuccessColor}"/>
                                    <TextBlock Text="在世人数" FontSize="12" 
                                               Foreground="{StaticResource SubTextColor}"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="12" FontSize="28" FontWeight="Bold" 
                                               Foreground="{StaticResource AccentColor}"/>
                                    <TextBlock Text="总代数" FontSize="12" 
                                               Foreground="{StaticResource SubTextColor}"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Grid.Column="3" Style="{StaticResource CardStyle}">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="3" FontSize="28" FontWeight="Bold" 
                                               Foreground="{StaticResource WarningColor}"/>
                                    <TextBlock Text="待审提交" FontSize="12" 
                                               Foreground="{StaticResource SubTextColor}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- 人物列表 -->
                        <TextBlock Text="人物列表" FontSize="16" FontWeight="Bold" 
                                   Margin="0,24,0,8"/>
                        
                        <!-- 搜索框 -->
                        <Border Background="#F5F0E8" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <Grid>
                                <TextBox PlaceholderText="🔍 搜索姓名、字辈、居住地..." 
                                         Style="{StaticResource InputStyle}"/>
                            </Grid>
                        </Border>

                        <!-- 人物表格（无边框轻量化） -->
                        <DataGrid ItemsSource="{Binding Persons}" 
                                  AutoGenerateColumns="False"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="#FAFAF5"
                                  HeadersVisibility="Column"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  SelectedItem="{Binding SelectedPerson}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="序号" Binding="{Binding Id}" Width="60"/>
                                <DataGridTextColumn Header="姓名" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="性别" Binding="{Binding GenderStr}" Width="60"/>
                                <DataGridTextColumn Header="出生" Binding="{Binding BirthDate}" Width="100"/>
                                <DataGridTextColumn Header="逝世" Binding="{Binding DeathDate}" Width="100"/>
                                <DataGridTextColumn Header="世系" Binding="{Binding Generation}" Width="60"/>
                                <DataGridTextColumn Header="居住地" Binding="{Binding Residence}" Width="*"/>
                                <DataGridTextColumn Header="状态" Binding="{Binding StatusStr}" Width="80"/>
                            </DataGrid.Columns>
                            <DataGrid.Style>
                                <Style TargetType="DataGrid">
                                    <Setter Property="CellStyle">
                                        <Setter.Value>
                                            <Style TargetType="DataGridCell">
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Padding" Value="12,8"/>
                                            </Style>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.Style>
                        </DataGrid>

                        <!-- 操作按钮 -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                            <Button Content="＋ 新增人物" Style="{StaticResource PrimaryButton}" 
                                    Margin="0,0,12,0" Padding="16,8"/>
                            <Button Content="📥 导入 Excel" Style="{StaticResource SecondaryButton}" 
                                    Margin="0,0,12,0" Padding="16,8"/>
                            <Button Content="📤 导出 PDF" Style="{StaticResource SecondaryButton}" 
                                    Padding="16,8"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- 底部状态栏 -->
        <Border Grid.ColumnSpan="2" Height="28" VerticalAlignment="Bottom" 
                Background="#F0EBE3" Padding="16,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📊 800人 | " FontSize="11" Foreground="{StaticResource SubTextColor}"/>
                <TextBlock Text="最后备份: 2026-07-16 12:00 | " FontSize="11" Foreground="{StaticResource SubTextColor}"/>
                <TextBlock Text="🟢 同步就绪" FontSize="11" Foreground="{StaticResource SuccessColor}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
