<Application x:Class="Hu.Editor.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- 新中式极简国风配色 -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#2C5F5C"/>      <!-- 黛青 -->
        <SolidColorBrush x:Key="SecondaryColor" Color="#3A3A3A"/>    <!-- 浅墨 -->
        <SolidColorBrush x:Key="BackgroundColor" Color="#F5F0E8"/>  <!-- 米白 -->
        <SolidColorBrush x:Key="AccentColor" Color="#C9A962"/>      <!-- 暖金 -->
        <SolidColorBrush x:Key="SuccessColor" Color="#7BA37B"/>     <!-- 竹青 -->
        <SolidColorBrush x:Key="WarningColor" Color="#C45B5B"/>     <!-- 赭石 -->
        <SolidColorBrush x:Key="CardBackgroundColor" Color="#E8E4DC"/> <!-- 月白 -->
        <SolidColorBrush x:Key="HoverColor" Color="#4A8B87"/>       <!-- 浅黛 -->
        <SolidColorBrush x:Key="TextColor" Color="#3A3A3A"/>
        <SolidColorBrush x:Key="SubTextColor" Color="#8B7355"/>     <!-- 沉香 -->
        <SolidColorBrush x:Key="DisabledColor" Color="#999999"/>

        <!-- 全局字体 -->
        <FontFamily x:Key="TitleFont">Microsoft YaHei UI, SimSun</FontFamily>
        <FontFamily x:Key="BodyFont">Microsoft YaHei UI, Segoe UI</FontFamily>

        <!-- 全局圆角 -->
        <CornerRadius x:Key="ButtonCornerRadius">8</CornerRadius>
        <CornerRadius x:Key="CardCornerRadius">12</CornerRadius>
        <CornerRadius x:Key="DialogCornerRadius">16</CornerRadius>
        <CornerRadius x:Key="InputCornerRadius">8</CornerRadius>

        <!-- 按钮样式 -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="CornerRadius" Value="{StaticResource ButtonCornerRadius}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource HoverColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1E4A47"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="{StaticResource DisabledColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 次按钮样式 -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
        </Style>

        <!-- 卡片样式 -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundColor}"/>
            <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#2C5F5C" Opacity="0.08" 
                                    BlurRadius="8" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 输入框样式 -->
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D0C8B8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CornerRadius" Value="{StaticResource InputCornerRadius}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- 标签样式 -->
        <Style x:Key="TagStyle" TargetType="Border">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Background" Value="#E3F2FD"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
    </Application.Resources>
</Application>
