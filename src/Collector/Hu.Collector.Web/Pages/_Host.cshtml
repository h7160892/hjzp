@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
    <title>安定堂胡氏家谱 · 信息采集</title>
    <base href="/" />
    <link rel="stylesheet" href="_content/Hu.Collector.Web/css/app.css">
</head>
<body>
    <div id="app">
        <style>
            body {
                margin: 0;
                font-family: 'Microsoft YaHei UI', sans-serif;
                background: #F5F0E8;
                display: flex;
                justify-content: center;
                align-items: center;
                min-height: 100vh;
            }
            #app {
                text-align: center;
                color: #3A3A3A;
            }
            .spinner {
                border: 3px solid #E8E4DC;
                border-top: 3px solid #2C5F5C;
                border-radius: 50%;
                width: 40px;
                height: 40px;
                animation: spin 1s linear infinite;
                margin: 0 auto 16px;
            }
            @keyframes spin {
                0% { transform: rotate(0deg); }
                100% { transform: rotate(360deg); }
            }
        </style>
        <div class="spinner"></div>
        <p>正在加载...</p>
    </div>

    <script src="_framework/blazor.webassembly.js"></script>
</body>
</html>
